					"baby_right_ear.rz": "new_right_ear.rz"
				},
				{
					"new_body.ty": "7 - (sin(clamp(var.counter, 0, pi)) * 4)",
					"baby_body.ty": "new_body.ty - 7.5",
					"new_body.rx": "torad(-30) + (sin(clamp(var.counter, 0, pi)) / 2)",
					"baby_body.rx": "new_body.rx",
					"new_head.rx": "head.rx - new_body.rx - torad(30)",
					"baby_head.rx": "new_head.rx",
					"new_left_arm.tz": "-8 - (sin(clamp(var.counter, -100, pi)) * 2.2)",
					"baby_left_arm.tz": "(new_left_arm.tz / 4.5) - 3.58",
					"new_left_arm.rx": "torad(30) - (sin(clamp(var.counter, -100, pi)))",
					"baby_left_arm.rx": "new_left_arm.rx",
					"new_right_arm.tz": "-8 - (sin(clamp(var.counter, -100, pi)) * 2.2)",
