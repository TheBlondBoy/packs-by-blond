	"models": [
		{
			"part": "head",
			"id": "head",
			"invertAxis": "xy",
			"translate": [0, -7.5, 3],
			"animations": [
				{
					"varb.in_editor": "is_on_shoulder",
					"var.counter": "if(age > 10, abs(age - var.age_at_last_jump) / 2.5, 100)",
					"var.age_at_last_jump": "if(!is_on_ground && limb_swing > 0 && abs(age - var.age_at_last_jump) > 10, age, var.age_at_last_jump)"
				},
				{
					"adult.sx": "if(is_child, 0, 1)",
					"adult.sy": "if(is_child, 0, 1)",
					"adult.sz": "if(is_child, 0, 1)",
					"baby.sx": "if(is_child, if(varb.in_editor, 1, 1.5), 0)",
					"baby.sy": "if(is_child, if(varb.in_editor, 1, 1.5), 0)",
					"baby.sz": "if(is_child, if(varb.in_editor, 1, 1.5), 0)"
				},
				{
					"body.sx": "if(varb.in_editor, 1, 1.6666)",
					"body.sy": "if(varb.in_editor, 1, 1.6666)",
					"body.sz": "if(varb.in_editor, 1, 1.6666)",
					"body.rx": "if(varb.in_editor, 0, torad(0))",
					"body.ty": "if(varb.in_editor, 16, 10.6666)",
					"body.tz": "if(varb.in_editor, 7, 11.575)"
				},
				{
					"new_head.ry": "head.ry",
					"baby_head.ry": "new_head.ry",
					"new_head.rz": "head.rz",
					"baby_head.rz": "new_head.rz",
					"new_left_ear.rx": "0 + clamp((head.rx * 0.25), -90, 0)",
					"baby_left_ear.rx": "new_left_ear.rx",
					"new_right_ear.rx": "0 + clamp((head.rx * 0.25), -90, 0)",
